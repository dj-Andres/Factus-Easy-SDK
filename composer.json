{
    "name": "factus-easy/factus-easy-sdk",
    "description": "SDK PHP para la API de Factus Easy - Facturacion Electronica SRI Ecuador",
    "type": "library",
    "license": "MIT",
    "keywords": ["factus-easy", "sri", "ecuador", "facturacion-electronica", "sdk"],
    "authors": [
        {
            "name": "Diego Jimenez",
            "email": "andres96jimenez@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "FactusEasy\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FactusEasy\\Sdk\\Tests\\": "tests/"
        }
    }
}
