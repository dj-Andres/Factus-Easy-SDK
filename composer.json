{
    "name": "factus-easy/factus-easy-sdk",
    "description": "SDK PHP para la API de Factus Easy - Facturacion Electronica SRI Ecuador",
    "type": "library",
    "license": "MIT",
    "keywords": ["factus-easy", "sri", "ecuador", "facturacion-electronica", "sdk"],
    "homepage": "https://factuseasy.kreativesofts.com",
    "authors": [
        {
            "name": "Diego Jimenez",
            "email": "andres96jimenez@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/dj-Andres/Factus-Easy-SDK/issues",
        "source": "https://github.com/dj-Andres/Factus-Easy-SDK"
    },
    "require": {
        "php": "^8.3",
        "guzzlehttp/guzzle": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "laravel/pint": "^1.16",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "FactusEasy\\Sdk\\": "src/"
        }
    },
    "scripts": {
        "example:login": "@php examples/auth/login.php",
        "example:register": "@php examples/auth/register.php",
        "example:companies": "@php examples/companies/list.php",
        "example:invoice": "@php examples/documents/register-invoice.php",
        "example:status": "@php examples/documents/status.php",
        "example:ride": "@php examples/documents/ride.php",
        "example:certificate": "@php examples/companies/certificate.php",
        "lint": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse --no-progress src/"
    }
}
